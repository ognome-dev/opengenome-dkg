# ─── Base Mainnet RPC ───────────────────────────────────────────────────────
# Public endpoint (rate-limited) or use Alchemy/Infura for reliability
BASE_RPC_URL=https://mainnet.base.org

# ─── DKG Operational Wallet ─────────────────────────────────────────────────
# Wallet that signs DKG publish transactions + holds TRAC
DKG_WALLET_ADDRESS=0x88BCDe7476E624739f083B96C4E884fF1DdF73E6
DKG_WALLET_PRIVATE_KEY=your_private_key_here

# ─── Management Wallet ──────────────────────────────────────────────────────
# Public key only — used for admin/management functions
# Can be the same address as DKG_WALLET_ADDRESS for edge nodes
EVM_MANAGEMENT_PUBLIC_KEY=0x88BCDe7476E624739f083B96C4E884fF1DdF73E6

# ─── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_PASSWORD=choose_a_strong_password_here
